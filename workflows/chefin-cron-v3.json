    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [ { "name": "Content-Type", "value": "application/json" } ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"temperature\": 0.5,\n  \"max_tokens\": 700,\n  \"messages\": [\n    {\"role\":\"system\",\"content\":\"Sos Chefin. Generás un resumen mensual conversacional, en español rioplatense (Argentina), para WhatsApp. Usá *negrita* para datos clave (montos, categorías, % cambios) y _cursiva_ para descripciones o notas. Tono cálido, directo, no condescendiente. Máximo 1500 chars. Estructura: 1) encabezado con el mes en *negrita*, 2) 2-3 párrafos cortos con la historia (qué subió/bajó vs el mes anterior, qué se nota en los datos, suscripciones nuevas si aparecen), 3) UNA recomendación accionable concreta al final. Si en el JSON `cashflow` viene `null`, NO menciones ingresos, saldo, ni 'cuánto te queda', NO sugieras cargar ingresos. Hacés el resumen solo con gastos. Devolvé SOLO el texto del mensaje, sin JSON ni explicaciones extra.\"},\n    {\"role\":\"user\",\"content\":\"Datos del mes para el resumen:\\n{{ JSON.stringify($json.snapshot) }}\"}\n  ]\n}",
        "options": {}
      },
      "id": "c041",
      "name": "Generate Digest LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [ 1100, 1400 ],
      "credentials": { "openAiApi": { "id": "yWzjxEHJ670U5FFO", "name": "OpenAI account" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst fmt = n => Number(n||0).toLocaleString('es-AR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });\nconst out = [];\nfor (const it of items) {\n  const j = it.json || {};\n  // 'Claim Digests' produce { user_id, phone, period_key, snapshot } — pero después del HTTP node, eso queda en el item original.\n  // Buscamos el snapshot via Claim Digests, y el text via la respuesta de OpenAI.\n  const claim = (typeof $('Claim Digests') !== 'undefined') ? ($('Claim Digests').all()[$itemIndex]?.json || {}) : j;\n  const snap = claim.snapshot || j.snapshot || {};\n  const userId = claim.user_id || j.user_id;\n  const phone  = claim.phone   || j.phone;\n  const periodKey = claim.period_key || j.period_key || (snap.period_key || 'último mes');\n  const monthLabel = snap.month_label || periodKey;\n  let body = '';\n  // Intento usar la respuesta de OpenAI\n  const llmText = j?.choices?.[0]?.message?.content;\n  if (typeof llmText === 'string' && llmText.trim().length > 30) {\n    body = llmText.trim();\n  } else {\n    // Fallback determinístico\n    const t = snap.totals || {};\n    const exp = Number(t.expenses_this || 0);\n    const expPrev = Number(t.expenses_prev || 0);\n    const delta = expPrev > 0 ? Math.round((exp - expPrev) / expPrev * 100) : null;\n    const trend = delta === null ? '' : (delta >= 0 ? ` (*+${delta}%* vs mes anterior)` : ` (*${delta}%* vs mes anterior)`);\n    body = `📅 *Resumen de ${monthLabel}*\\nGastaste *$${fmt(exp)}* en _${t.count_this||0} movimientos_${trend}.`;\n    if (Array.isArray(snap.by_category) && snap.by_category.length > 0) {\n      const top = snap.by_category.slice(0, 3).map((c,i) => `${i+1}. *${c.category||'sin'}* — *$${fmt(c.this_month||0)}*`).join('\\n');\n      body += `\\n\\n*Top categorías:*\\n${top}`;\n    }\n    if (snap.has_income && snap.cashflow) {\n      body += `\\n\\n*Saldo del mes:* *$${fmt(snap.cashflow.net||0)}* (ingresos *$${fmt(snap.cashflow.income||0)}* - gastos *$${fmt(snap.cashflow.expenses||0)}*).`;\n    }\n  }\n  if (!userId || !phone) continue;\n  out.push({ json: {\n    job_name: 'monthly_digest',\n    user_id: userId, phone,\n    instance: 'chefin',\n    remoteJid: phone + '@s.whatsapp.net',\n    replyText: body\n  }});\n}\nreturn out;"
      },
      "id": "c042",
      "name": "Format Digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 1320, 1400 ]
