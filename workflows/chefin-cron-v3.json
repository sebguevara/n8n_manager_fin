      "parameters": {
        "jsCode": "const items = $input.all().filter(i => i.json && i.json.user_id && Number(i.json.new_count || 0) > 0);\nconst fmt = n => Number(n||0).toLocaleString('es-AR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });\nconst out = [];\nfor (const it of items) {\n  const j = it.json;\n  const list = (j.items || []).slice(0, 6).map((s, i) => {\n    const desc = s.description || s.category || 'recurrente';\n    return `${i+1}. _${desc}_ · *$${fmt(s.avg_amount)}* · *${s.cadence || 'mensual'}* · próximo *${s.next_date || '—'}*`;\n  }).join('\\n');\n  const body = `🔍 *Suscripciones nuevas detectadas* (~*$${fmt(j.monthly_total)}*/mes):\\n${list}\\n\\nSi querés que las marque como recurrentes en el sistema, decime cuáles.`;\n  out.push({ json: {\n    job_name: 'subscriptions',\n    user_id: j.user_id, phone: j.phone,\n    instance: 'chefin',\n    remoteJid: j.phone + '@s.whatsapp.net',\n    replyText: body\n  }});\n}\nreturn out;"
      },
