    {
      "parameters": {
        "jsCode": "const items = $input.all().filter(i => i.json && i.json.user_id);\nconst fmt = n => Number(n||0).toLocaleString('es-AR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });\nconst out = [];\nfor (const it of items) {\n  const j = it.json;\n  const cat = j.category_name || 'sin categoría';\n  const desc = j.description ? ` (_${j.description}_)` : '';\n  const mult = Number(j.multiplier || 0);\n  const baseline = Number(j.baseline || 0);\n  const amount = Number(j.amount || 0);\n  const body = `🚨 *Gasto fuera de lo normal*\\nHoy gastaste *$${fmt(amount)}* en *${cat}*${desc} — *${mult.toFixed(1)}x* tu promedio (*$${fmt(baseline)}*).\\n¿Es correcto? Decime *no* si fue un error y lo borro.`;\n  out.push({ json: {\n    job_name: 'anomalies',\n    user_id: j.user_id, phone: j.phone,\n    instance: 'chefin',\n    remoteJid: j.phone + '@s.whatsapp.net',\n    replyText: body\n  }});\n}\nreturn out;"
      },
