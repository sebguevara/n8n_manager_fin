    {
      "parameters": {
        "jsCode": "const items = $input.all().filter(i => i.json.user_id);\nconst fmt = n => Number(n||0).toLocaleString('es-AR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });\nconst periodLabel = p => ({ weekly:'esta semana', monthly:'este mes', yearly:'este año' })[p] || p;\nconst out = [];\nfor (const it of items) {\n  const j = it.json;\n  const spent     = Number(j.spent || 0);\n  const amount    = Number(j.amount || 0);\n  const pct       = Number(j.pct || 0);\n  const remaining = Number(j.remaining_amount || 0);\n  const daysRem   = Number(j.days_remaining || 0);\n  const safeDaily = Number(j.safe_daily || 0);\n  const catLabel  = (j.category_emoji ? j.category_emoji + ' ' : '') + '*' + j.category_name + '*';\n  const pl        = periodLabel(j.period);\n  let body;\n  switch (j.level) {\n    case 'over_critical':\n      body = `🔴 *Te pasaste fuerte de ${catLabel}* (${pl})\\nLlevás *$${fmt(spent)}* / *$${fmt(amount)}* (*${pct}%*).\\nFaltan *${daysRem} días* — para no escalar más, frená esta categoría hasta el cierre del período.`;\n      break;\n    case 'over_budget':\n      body = `🟠 *Te pasaste de ${catLabel}* (${pl})\\nLlevás *$${fmt(spent)}* / *$${fmt(amount)}* (*${pct}%*).\\nQuedan *${daysRem} días* — cualquier gasto extra suma sobre el exceso.`;\n      break;\n    case 'near_budget':\n      body = `🟡 *Vas cerca del límite de ${catLabel}* (${pl})\\nLlevás *$${fmt(spent)}* / *$${fmt(amount)}* (*${pct}%*).\\nTe quedan *$${fmt(remaining)}* para *${daysRem} días* = *$${fmt(safeDaily)}/día*.`;\n      break;\n    case 'pacing_warn':\n    default:\n      body = `🟢 *Heads up — ${catLabel}* (${pl})\\nLlevás *$${fmt(spent)}* / *$${fmt(amount)}* (*${pct}%*) y vas adelantado en el período.\\nPara no pasarte: *$${fmt(remaining)}* para *${daysRem} días* = *$${fmt(safeDaily)}/día*.`;\n      break;\n  }\n  out.push({ json: {\n    job_name: 'budget_alerts',\n    user_id: j.user_id, phone: j.phone,\n    instance: 'chefin',\n    remoteJid: j.phone + '@s.whatsapp.net',\n    replyText: body,\n    _budget_id: j.budget_id, _level: j.level\n  }});\n}\nreturn out;"
      },
