    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT CASE\n        WHEN $1::text = 'budget_alerts' AND $2 IS NOT NULL AND $3 IS NOT NULL\n        THEN (SELECT mark_budget_alert_sent($2::uuid, $3::uuid, $4::text))\n        ELSE NULL END AS marked;",
        "options": {
